+  await assertProjectAccess(projectId, userId, scope);
+  const parsed = ProjectThemesSchema.safeParse(themesUnsafe);
+  if (!parsed.success) throw new Error("Formato de temas inválido");
+  await ensureProjectThemesTable();
+  const themes = parsed.data.map((t) => ({
+    id: String(t.id).trim(),
