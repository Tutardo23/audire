+++ b/src/app/api/families/analyze/route.ts
@@ -0,0 +1,53 @@
+import { NextResponse } from "next/server";
+import { SHEETS_BY_GROUP, type FamilyGroup } from "../../../lib/familyImportConfig";
+
+export async function POST(req: Request) {
+  try {
+    const form = await req.formData();
+    const group = String(form.get("group") || "") as FamilyGroup;
+    const file = form.get("file");
+    if (!group || !SHEETS_BY_GROUP[group]) return NextResponse.json({ error: "Grupo inválido." }, { status: 400 });
+    if (!(file instanceof File)) return NextResponse.json({ error: "Archivo inválido." }, { status: 400 });
+
+    let XLSX: any;
+    try {
+      XLSX = await import("xlsx");
+    } catch {
+      return NextResponse.json({ error: "Falta dependencia xlsx en el servidor." }, { status: 500 });
+    }
+
+    const ab = await file.arrayBuffer();
+    const wb = XLSX.read(Buffer.from(ab), { type: "buffer" });
+    const actualSheets = wb.SheetNames;
+    const expected = SHEETS_BY_GROUP[group];
+
+    const details = actualSheets.map((name: string) => {
+      const ws = wb.Sheets[name];
+      const rows = XLSX.utils.sheet_to_json(ws, { defval: null });
+      return { hoja: name, filasDetectadas: rows.length };
+    });
+
+    const missing = expected.filter((s: { hoja: string }) => !actualSheets.includes(s.hoja)).map((s: { hoja: string }) => s.hoja);
+    const unexpected = actualSheets.filter((s: string) => !expected.some((e: { hoja: string }) => e.hoja === s));
+    const matched = expected
+      .filter((s: { hoja: string }) => actualSheets.includes(s.hoja))
+      .map((s: { hoja: string; filas: number }) => {
+        const got = details.find((d: { hoja: string; filasDetectadas: number }) => d.hoja === s.hoja)?.filasDetectadas || 0;
+        return { hoja: s.hoja, esperado: s.filas, detectado: got, delta: got - s.filas };
+      });
+
+    return NextResponse.json({
+      ok: true,
+      resumen: {
+        hojasDetectadas: actualSheets.length,
+        hojasEsperadas: expected.length,
+        faltantes: missing,
+        inesperadas: unexpected,
+      },
+      details,
+      matched,
+    });
+  } catch {
+    return NextResponse.json({ error: "No se pudo analizar el archivo." }, { status: 500 });
+  }
+}
